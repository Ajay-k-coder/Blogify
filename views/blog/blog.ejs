<%- include("../layouts/boilerplate") %>
<body class="container bg-dark text-white">
    <div>
        <h1> Hello <%- blog.title %></h1>
        <img src="<%-blog.path %>" class="img-fluid">
        <div class="m-4 text-justify">
            <%- blog.content %>
        </div>
    </div>
    <hr>
    <% if(locals.user) { %>
     

    <div class="container m-5">
        <div class="text-left">
        <form method="post" action=" <%- blog._id %>/comment" class="mt-5 row">
        <label for="email" class="form-label">Comment</label>
        <div class="row">
        <div class="col-8">
            <input type="text" name="comment" class="form-control">
        </div>
        <div class="col-2">
            <button class="form-control btn btn-success" >Add</button>
        </div>
        </div>
        
    </form>
        </div>
    </div>
     <% } %>

    <div class="container row">
        <% comments.forEach( comment => { %>

            <div class="d-flex justify-content-start align-items-center">
                <img src="<%=comment.commitedBy.profilePicture %>"  width= "60px" height="60px"  class="border border-white m-2 rounded-circle"  alt="..."> <span class="fw-bold ms-2"> <%= comment.commitedBy.name%>  </span>
                
                
                <br>
                <p class="text-left ms-5 ps-3 mt-3">:   <%- comment.comment %></p> 
            </div>
            <hr>
         
        <% }) %>
    </div>
    
</body>