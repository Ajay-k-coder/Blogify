 
<%- include("layouts/boilerplate") %>



<body class="container text-white" style="background-color:black;">
    <form  method="post" action="/user/signup" enctype="multipart/form-data">

        <div class="mb-3 mt-4">
            <label for="formFile" class="form-label">Image</label>
            <input class="form-control" type="file" id="formFile" name="profilePicture">
        </div>

        <label for="fullname" class="form-label"> Full Name </label>
        <input type="text" name="name" id="fullname" class="form-control">
        
        <label for="dob" class="form-label"> Date of Birth</label>
        <input type="date" name="age" id="dob" class="form-control">
        
        <label for="contact" class="form-label">Contact</label>
        <input type="number" id="contact" name="contact" class="form-control">
        
        <label for="email" class="form-label">Email</label>
        <input type="email"   name="email" class="form-control">
        
        <label for="password" class="form-label">password</label>
        <input type="password" id="password" autocomplete="section-blue shipping street-address" name="password" class="form-control">

        <label for="address" class="form-label">Address</label>
        <input type="address" id="address" name="address" class="form-control">

        <div class="d-grid gap-2 col-6 mx-auto mb-5">   
            <button class="form-control btn btn-primary">SignUp</button>
        </div>

        </form>
        
</body>
</html>